# Copia este archivo a `.env` y completa los valores (`.env` no se sube a Git).
DJANGO_SECRET_KEY=cambia-esto-por-una-clave-larga-y-aleatoria
POSTGRES_DB=ros_db
POSTGRES_USER=postgres
POSTGRES_PASSWORD=
POSTGRES_HOST=127.0.0.1
POSTGRES_PORT=5432

# SMTP (correo real). Para Gmail usa una "App Password" (si tienes 2FA).
# OJO: no pongas tu contraseña de Gmail normal si tienes 2FA; usa la App Password.
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=tu_correo@gmail.com
SMTP_PASSWORD=tu_app_password
SMTP_USE_TLS=true
SMTP_USE_SSL=false
EMAIL_FROM=tu_correo@gmail.com
